sequenceDiagram
    actor User
    participant UI as Streamlit UI
    participant App as BrowserApp
    participant List as BrowserHistory
    participant DB as DatabaseManager
    participant SQLite

    User->>UI: Enter URL and click "Visit"
    UI->>App: visit(url)
    App->>App: is_valid_url(url)
    App->>List: show_current()
    List-->>App: current_node
    alt URL equals current
        App-->>UI: raise DuplicateVisitError
        UI-->>User: Show warning message
    else URL is new
        App->>List: visit(normalized_url)
        List->>List: delete_forward_history() if needed
        List->>List: create Node, link prev/next
        List-->>App: new_node
        App->>App: save_to_database()
        App->>List: show_history()
        List-->>App: all nodes (head to tail)
        App->>DB: save_all(rows)
        DB->>SQLite: DELETE FROM history; INSERT rows
        SQLite-->>DB: commit OK
        DB-->>App: success
        App-->>UI: new_node
        UI-->>User: Re-render with new current page
    end
